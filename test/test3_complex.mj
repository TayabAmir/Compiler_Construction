program ComplexExample
final int SIZE = 100;
int globalcounter;

class Data {
    int value;
    int flag;
}
{
void compute(int n)
    int localsum;
    int i;
{
    localsum = 0;
    i = 0;
    while (i < n) {
        localsum = localsum + i;
        i = i + 1;
    }
    print(localsum);
    return;
}

void main()
    int result;
    int temp;
{
    result = 0;
    temp = SIZE;
    read(result);
    if (result > 0) {
        compute(result);
        print(result);
    } else {
        temp = -1;
        print(temp);
    }
    while (result != 0) {
        result = result - 1;
        print(result);
    }
    return;
}
}
